msgid "Cap CAPTCHA Configuration"
msgstr "Cap-CAPTCHA-Konfiguration"

msgid "Cap Server URL"
msgstr "Cap-Server-URL"

msgid "The URL of your self-hosted Cap server, e.g. https://captcha.example.com"
msgstr "Die URL Ihres selbst gehosteten Cap-Servers, z.B. https://captcha.example.com"

msgid "Site Key"
msgstr "Seitenschlüssel"

msgid "The site key from your Cap server dashboard."
msgstr "Der Seitenschlüssel aus Ihrem Cap-Server-Dashboard."

msgid "API Secret"
msgstr "API-Schlüssel"

msgid "The secret key used for server-side token verification."
msgstr "Der geheime Schlüssel für die serverseitige Token-Verifizierung."

msgid "Cap CAPTCHA"
msgstr "Cap CAPTCHA"

msgid "Adds a proof-of-work CAPTCHA to protect your form from spam."
msgstr "Fügt ein Proof-of-Work-CAPTCHA hinzu, um Ihr Formular vor Spam zu schützen."

msgid "Cap CAPTCHA Widget"
msgstr "Cap-CAPTCHA-Widget"

msgid "Please complete the CAPTCHA verification."
msgstr "Bitte schliessen Sie die CAPTCHA-Verifizierung ab."

msgid "CAPTCHA verification is not configured. Please contact the site administrator."
msgstr "Die CAPTCHA-Verifizierung ist nicht konfiguriert. Bitte kontaktieren Sie den Website-Administrator."

msgid "CAPTCHA verification failed due to a network error. Please try again."
msgstr "CAPTCHA-Verifizierung aufgrund eines Netzwerkfehlers fehlgeschlagen. Bitte versuchen Sie es erneut."

msgid "CAPTCHA verification failed. Please try again."
msgstr "CAPTCHA-Verifizierung fehlgeschlagen. Bitte versuchen Sie es erneut."

msgid "Verify you are human"
msgstr "Sind Sie ein Mensch?"

msgid "Verifying..."
msgstr "Prüfung..."

msgid "Verified"
msgstr "Verifiziert"

msgid "Verification error"
msgstr "Verifizierungsfehler"

msgid "Having trouble?"
msgstr "Probleme?"

msgid "Please enable JavaScript to continue."
msgstr "Bitte aktivieren Sie JavaScript, um fortzufahren."

msgid "Click to verify you are human"
msgstr "Klicken zum Verifizieren"

msgid "Verification in progress"
msgstr "Verifizierung läuft"

msgid "Successfully verified"
msgstr "Erfolgreich verifiziert"

msgid "Verification failed"
msgstr "Verifizierung fehlgeschlagen"
